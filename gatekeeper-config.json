{
  "ports": [
    {
      "name": "9router",
      "enabled": true,
      "listen": ":20128",
      "command": "/home/user/.nvm/versions/node/current/bin/node /home/user/.nvm/versions/node/current/lib/node_modules/9router/cli.js start --host 0.0.0.0 -p 20128 --skip-update --no-browser",
      "stop_command": "/home/user/.nvm/versions/node/current/bin/node /home/user/9router/cli.js stop",
      "idle_minutes": 20,
      "monitor": {
        "enabled": true,
        "interval_seconds": 60,
        "log_dedup": "off"
      },
      "delay": 30000,
      "refresh_seconds": 15,
      "auto_restart": true
    }
  ]
}
