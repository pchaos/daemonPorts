{
  "ports": [
    {
      "name": "web",
      "enabled": true,
      "listen": ":3000",
      "backend": ":3001",
      "command": "./real-app --port 3001",
      "delay": 500,
      "auto_restart": false
    },
    {
      "name": "api",
      "enabled": false,
      "listen": ":4000",
      "backend": ":4001",
      "command": "./api-server --port 4001",
      "delay": 1000,
      "auto_restart": true
    }
  ]
}