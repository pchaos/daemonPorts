{
  "ports": [
    {
      "name": "web",
      "enabled": true,
      "listen": ":3000",
      "command": "./real-app --port 3000",
      "delay": 5000,
      "refresh_seconds": 3,
      "auto_restart": false
    },
    {
      "name": "api",
      "enabled": false,
      "listen": ":4000",
      "command": "./api-server --port 4000",
      "delay": 5000,
      "refresh_seconds": 3,
      "auto_restart": true
    }
  ]
}